# Pooled connection (used at runtime, transaction-level pooling).
# On Neon: copy the "Pooled connection" string and add ?pgbouncer=true&connection_limit=1
# Example:
# DATABASE_URL="postgresql://USER:PASS@HOST-pooler.eu-central-1.aws.neon.tech/DBNAME?sslmode=require&pgbouncer=true&connection_limit=1"
DATABASE_URL=""

# Direct (unpooled) connection. Used by `prisma db push` / migrations.
# On Neon: copy the "Direct connection" string (host without -pooler).
# Example:
# DIRECT_URL="postgresql://USER:PASS@HOST.eu-central-1.aws.neon.tech/DBNAME?sslmode=require"
DIRECT_URL=""
